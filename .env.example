# Authkey.io — SMS OTP
AUTHKEY_API_KEY=
AUTHKEY_SENDER_ID=

# Session signing secret (generate a random string for production)
SESSION_SECRET=change-this-to-a-random-secret

# Local dev only: skip real SMS; any 6-digit OTP works. Never set in production.
# NEXT_PUBLIC_DEV_OTP_BYPASS=true

# Firebase — client (Firebase Console → Project settings → Your apps → Web)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — verify ID tokens (server)
# A) Path to service account JSON:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# B) Or: GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to-adminsdk.json
# C) Or: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# MongoDB — profiles + loans (database name is the path segment, e.g. .../smart)
# MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/smart

# Admin bootstrap (optional) — before setting is_admin in MongoDB
# ADMIN_PHONE_E164=+919876543210
# ADMIN_EMAIL=you@gmail.com
# ADMIN_FIREBASE_UID=firebase_auth_uid_of_admin
