# Copy to .env.local — Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy JWT "anon" key, or newer "publishable" key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Authentication → Providers: enable Phone (Twilio / MessageBird / etc.)

# Dev only: accept any OTP (no real SMS). Never ship with this true.
# NEXT_PUBLIC_DEV_OTP_BYPASS=true

# Database: run SQL in supabase/migrations/ in the Supabase SQL editor (profiles + loans).
