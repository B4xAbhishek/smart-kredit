# Authkey.io — SMS OTP
AUTHKEY_API_KEY=060e68f5f958f601
AUTHKEY_SENDER_ID=SMTKRD

# Session signing secret (generate a random string for production)
SESSION_SECRET=change-this-to-a-random-secret

# Local dev only: skip real SMS; any 6-digit OTP works. Never set in production.
# NEXT_PUBLIC_DEV_OTP_BYPASS=true

# Supabase (for database + Google OAuth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only — admin console + OTP→profile sync (Dashboard → API → service_role secret)
# SUPABASE_SERVICE_ROLE_KEY=

# Admin bootstrap (phone or email) — no DB required for first admin
# ADMIN_PHONE_E164=+919876543210
# ADMIN_EMAIL=you@gmail.com

# Google OAuth setup:
# 1. Supabase Dashboard → Auth → Providers → Google → Enable
# 2. Add OAuth credentials from Google Cloud Console
# 3. Add redirect URL to Google: https://<your-project>.supabase.co/auth/v1/callback
# 4. No extra env vars needed — Supabase handles the OAuth exchange
